#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: agent_scripts/declare_files <action> <id_kind> <id> [files...]
  action:   declare | release
  id_kind:  session | task
  id:       BT_SESSION_ID for terminal tabs, BT_TASK_ID for task terminals
  files:    repo-relative write-target paths (required for declare)
EOF
}

json_escape() {
  local value="$1"
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

if [[ $# -lt 3 ]]; then
  usage
  exit 1
fi

action="$1"
id_kind="$2"
owner_id="$3"
shift 3

if [[ "$action" != "declare" && "$action" != "release" ]]; then
  echo "declare_files failed: action must be declare or release" >&2
  usage
  exit 1
fi

if [[ "$id_kind" != "session" && "$id_kind" != "task" ]]; then
  echo "declare_files failed: id_kind must be session or task" >&2
  usage
  exit 1
fi

if [[ -z "${owner_id// }" ]]; then
  echo "declare_files failed: id must be non-empty" >&2
  usage
  exit 1
fi

to_short_task_id() {
  local value="$1"
  if [[ "$value" =~ ^[a-z_]+_(.+)$ ]]; then
    printf '%s' "${BASH_REMATCH[1]}"
    return
  fi
  printf '%s' "$value"
}

env_task_id="${BT_TASK_ID:-}"
env_session_id="${BT_SESSION_ID:-}"
if [[ -n "$env_task_id" && "$id_kind" == "session" && -n "$env_session_id" && "$owner_id" == "$env_session_id" ]]; then
  echo "declare_files info: BT_TASK_ID is set; using task claim for this terminal" >&2
  id_kind="task"
  owner_id="$env_task_id"
fi

if [[ -n "$env_task_id" && "$id_kind" == "task" ]]; then
  env_task_short="$(to_short_task_id "$env_task_id")"
  if [[ "$owner_id" == "$env_task_short" && "$owner_id" != "$env_task_id" ]]; then
    echo "declare_files info: short task id detected; using full BT_TASK_ID" >&2
    owner_id="$env_task_id"
  fi
fi

server_url="${BT_SERVER_URL:-http://localhost:3001}"
declare_endpoint="${server_url%/}/orchestrator/declare-files"
release_endpoint="${server_url%/}/orchestrator/release-files"
requested_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

request() {
  local method="$1"
  local endpoint="$2"
  local payload="${3:-}"
  local output_file="$4"

  if [[ -n "$payload" ]]; then
    curl -sS \
      -o "$output_file" \
      -w "%{http_code}" \
      -X "$method" "$endpoint" \
      -H "Content-Type: application/json" \
      --data "$payload"
  else
    curl -sS \
      -o "$output_file" \
      -w "%{http_code}" \
      -X "$method" "$endpoint"
  fi
}

describe_wait_status() {
  local response_file="$1"
  node - "$response_file" <<'EOF'
const fs = require('fs');

const responsePath = process.argv[2];
if (!responsePath) process.exit(0);

let payload;
try {
  payload = JSON.parse(fs.readFileSync(responsePath, 'utf8'));
} catch {
  process.exit(0);
}

if (!payload || payload.status !== 'wait') process.exit(0);

const parts = [];
if (typeof payload.queuePosition === 'number' && Number.isFinite(payload.queuePosition)) {
  parts.push(`queue=${payload.queuePosition}`);
}

const reasonLabels = {
  'active-conflict': 'active conflict',
  'queued-upgrade-conflict': 'queued upgrade conflict',
  'queued-new-conflict': 'queued new conflict',
};
if (typeof payload.waitReason === 'string' && reasonLabels[payload.waitReason]) {
  parts.push(`reason=${reasonLabels[payload.waitReason]}`);
}

if (Array.isArray(payload.blockingOwners) && payload.blockingOwners.length > 0) {
  const ownerLabels = payload.blockingOwners
    .map((owner) => {
      if (!owner || typeof owner !== 'object') return null;
      const ownerKey =
        typeof owner.ownerKey === 'string' && owner.ownerKey.trim() ? owner.ownerKey.trim() : null;
      if (!ownerKey) return null;
      const label = typeof owner.label === 'string' && owner.label.trim() ? owner.label.trim() : null;
      const workspaceTitle =
        typeof owner.workspaceTitle === 'string' && owner.workspaceTitle.trim()
          ? owner.workspaceTitle.trim()
          : null;
      let description = ownerKey;
      if (label) description += ` \"${label}\"`;
      if (workspaceTitle) description += ` @${workspaceTitle}`;
      return description;
    })
    .filter(Boolean);
  if (ownerLabels.length > 0) {
    parts.push(`owners=${ownerLabels.join(',')}`);
  }
} else if (Array.isArray(payload.blockingOwnerKeys) && payload.blockingOwnerKeys.length > 0) {
  parts.push(`owners=${payload.blockingOwnerKeys.join(',')}`);
}

if (Array.isArray(payload.blockingFiles) && payload.blockingFiles.length > 0) {
  parts.push(`files=${payload.blockingFiles.join(',')}`);
}

if (parts.length > 0) {
  process.stdout.write(` (${parts.join('; ')})`);
}
EOF
}

resolve_claim_scope() {
  local git_root=""
  if git_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    if [[ -n "${git_root// }" ]]; then
      printf '%s' "$git_root"
      return
    fi
  fi
  pwd -P
}

if [[ "$action" == "declare" ]]; then
  if [[ $# -lt 1 ]]; then
    echo "declare_files failed: declare requires at least one file path" >&2
    usage
    exit 1
  fi

  declare -a files=("$@")
  seen_lines=$'\n'
  declare -a deduped=()
  for file in "${files[@]}"; do
    normalized="${file#./}"
    if [[ -z "${normalized// }" ]]; then
      echo "declare_files failed: file path cannot be empty" >&2
      exit 1
    fi
    if [[ "$seen_lines" == *$'\n'"$normalized"$'\n'* ]]; then
      continue
    fi
    seen_lines+="${normalized}"$'\n'
    deduped+=("$normalized")
  done

  files_json=""
  for file in "${deduped[@]}"; do
    escaped_file="$(json_escape "$file")"
    if [[ -z "$files_json" ]]; then
      files_json="\"$escaped_file\""
    else
      files_json+=",\"$escaped_file\""
    fi
  done

  claim_scope="$(resolve_claim_scope)"
  payload="{\"idKind\":\"$(json_escape "$id_kind")\",\"id\":\"$(json_escape "$owner_id")\",\"files\":[${files_json}],\"scope\":\"$(json_escape "$claim_scope")\",\"requestedAt\":\"$(json_escape "$requested_at")\"}"
  response_file="$(mktemp)"
  if ! http_code="$(request "POST" "$declare_endpoint" "$payload" "$response_file")"; then
    echo "declare_files failed: could not reach $declare_endpoint" >&2
    rm -f "$response_file"
    exit 1
  fi

  if [[ "$http_code" != "200" ]]; then
    echo "declare_files failed (HTTP $http_code)" >&2
    if [[ -s "$response_file" ]]; then
      cat "$response_file" >&2
    fi
    rm -f "$response_file"
    exit 1
  fi

  if grep -q '"status":"go"' "$response_file"; then
    rm -f "$response_file"
    echo "declare_files granted for ${id_kind}:${owner_id}"
    exit 0
  fi

  if ! grep -q '"status":"wait"' "$response_file"; then
    echo "declare_files failed: unexpected declare response" >&2
    cat "$response_file" >&2
    rm -f "$response_file"
    exit 1
  fi
  rm -f "$response_file"

  status_endpoint="${server_url%/}/orchestrator/claim-status/$id_kind/$owner_id"
  wait_started_at="$(date +%s)"
  next_heartbeat_at=$((wait_started_at + 10))
  while true; do
    poll_file="$(mktemp)"
    if ! http_code="$(request "GET" "$status_endpoint" "" "$poll_file")"; then
      echo "declare_files failed: could not reach $status_endpoint" >&2
      rm -f "$poll_file"
      exit 1
    fi
    if [[ "$http_code" != "200" ]]; then
      echo "declare_files failed while polling (HTTP $http_code)" >&2
      if [[ -s "$poll_file" ]]; then
        cat "$poll_file" >&2
      fi
      rm -f "$poll_file"
      exit 1
    fi
    if grep -q '"status":"go"' "$poll_file"; then
      rm -f "$poll_file"
      echo "declare_files granted for ${id_kind}:${owner_id}"
      exit 0
    fi
    if ! grep -q '"status":"wait"' "$poll_file"; then
      echo "declare_files failed: unexpected claim-status response" >&2
      cat "$poll_file" >&2
      rm -f "$poll_file"
      exit 1
    fi
    now="$(date +%s)"
    if (( now >= next_heartbeat_at )); then
      elapsed=$((now - wait_started_at))
      details="$(describe_wait_status "$poll_file")"
      echo "declare_files waiting (${elapsed}s) for ${id_kind}:${owner_id}${details}" >&2
      next_heartbeat_at=$((now + 10))
    fi
    rm -f "$poll_file"
    sleep 2
  done
fi

if [[ $# -ne 0 ]]; then
  echo "declare_files failed: release does not accept file paths" >&2
  usage
  exit 1
fi

payload="{\"idKind\":\"$(json_escape "$id_kind")\",\"id\":\"$(json_escape "$owner_id")\"}"
response_file="$(mktemp)"
if ! http_code="$(request "POST" "$release_endpoint" "$payload" "$response_file")"; then
  echo "declare_files failed: could not reach $release_endpoint" >&2
  rm -f "$response_file"
  exit 1
fi

if [[ "$http_code" != "200" ]]; then
  echo "declare_files failed (HTTP $http_code)" >&2
  if [[ -s "$response_file" ]]; then
    cat "$response_file" >&2
  fi
  rm -f "$response_file"
  exit 1
fi

if ! grep -q '"ok":true' "$response_file"; then
  echo "declare_files failed: unexpected release response" >&2
  cat "$response_file" >&2
  rm -f "$response_file"
  exit 1
fi

rm -f "$response_file"
echo "declare_files released for ${id_kind}:${owner_id}"
