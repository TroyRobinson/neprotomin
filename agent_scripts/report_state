#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 3 ]]; then
  echo "Usage: agent_scripts/report_state <task_id> <status> <message...>" >&2
  exit 1
fi

task_id="$1"
status="$2"
shift 2
message="$*"
server_url="${BT_SERVER_URL:-http://localhost:3001}"
endpoint="${server_url%/}/tasks/report-state"
reported_at="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
session_id="${BT_SESSION_ID:-}"

case "$status" in
  next_slice|committed|review_needed|planned|info|blocked)
    ;;
  *)
    echo "report_state failed: status must be one of next_slice, committed, review_needed, planned, info, blocked" >&2
    exit 1
    ;;
esac

if [[ -z "${message// }" ]]; then
  echo "report_state failed: message must be non-empty" >&2
  exit 1
fi

json_escape() {
  local value="$1"
  value=${value//\\/\\\\}
  value=${value//\"/\\\"}
  value=${value//$'\n'/\\n}
  value=${value//$'\r'/\\r}
  value=${value//$'\t'/\\t}
  printf '%s' "$value"
}

payload="{\"taskId\":\"$(json_escape "$task_id")\",\"status\":\"$(json_escape "$status")\",\"message\":\"$(json_escape "$message")\",\"reportedAt\":\"$(json_escape "$reported_at")\""
if [[ -n "$session_id" ]]; then
  payload+=",\"sessionId\":\"$(json_escape "$session_id")\""
fi
payload+="}"

response_file="$(mktemp)"
if ! http_code="$(
  curl -sS \
    -o "$response_file" \
    -w "%{http_code}" \
    -X POST "$endpoint" \
    -H "Content-Type: application/json" \
    --data "$payload"
)"; then
  echo "report_state failed: could not reach $endpoint" >&2
  rm -f "$response_file"
  exit 1
fi

if [[ "$http_code" != "200" ]]; then
  echo "report_state failed (HTTP $http_code)" >&2
  if [[ -s "$response_file" ]]; then
    cat "$response_file" >&2
  fi
  rm -f "$response_file"
  exit 1
fi

if ! grep -q '"ok":true' "$response_file"; then
  echo "report_state failed: unexpected response" >&2
  if [[ -s "$response_file" ]]; then
    cat "$response_file" >&2
  fi
  rm -f "$response_file"
  exit 1
fi

rm -f "$response_file"
echo "report_state accepted for task $task_id ($status)"
